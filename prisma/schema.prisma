generator client { provider = "prisma-client-js" }
datasource db { provider = "postgresql" url = env("DATABASE_URL") }

enum Role { admin attorney outreach_manager intake_staff }
enum Segment { founder existing_business_contracts trademark_brand referral_partner newsletter_only }
enum ConsentStatus { unknown opted_in opted_out existing_relationship }
enum RelationshipStatus { none existing_client former_client referral_partner professional_contact }
enum ConflictStatus { not_started needs_review cleared conflict_found declined }
enum ApprovalStatus { draft pending approved rejected }
enum MessageType { cold_outreach newsletter resource_follow_up transactional legal_administrative }
enum QueueStatus { draft blocked pending_review approved sent failed cancelled }
enum Jurisdiction { NY NJ OTHER }

model User {
  id String @id @default(cuid())
  email String @unique
  name String
  role Role
  passwordHash String?
  createdAt DateTime @default(now())
  templateApprovals Template[] @relation("TemplateApprover")
  resourceApprovals Resource[] @relation("ResourceApprover")
  campaignApprovals Campaign[] @relation("CampaignApprover")
  messageApprovals OutboundMessage[] @relation("MessageApprover")
  conflictClearances Lead[] @relation("ConflictClearer")
  auditLogs AuditLog[]
}

model Lead {
  id String @id @default(cuid())
  businessName String?
  contactName String
  email String @unique
  phone String?
  website String?
  state String
  source String?
  segment Segment
  notes String?
  consentStatus ConsentStatus @default(unknown)
  relationshipStatus RelationshipStatus @default(none)
  doNotContact Boolean @default(false)
  unsubscribedAt DateTime?
  conflictStatus ConflictStatus @default(not_started)
  conflictNotes String?
  conflictClearedAt DateTime?
  conflictClearedById String?
  conflictClearedBy User? @relation("ConflictClearer", fields: [conflictClearedById], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  intakeAnswers IntakeAnswer[]
  messages OutboundMessage[]
  consultations Consultation[]
}

model IntakeAnswer {
  id String @id @default(cuid())
  leadId String
  lead Lead @relation(fields: [leadId], references: [id])
  businessType String?
  state String
  legalNeedCategory String
  urgency String
  opposingParties String?
  existingLawyerInvolvement String?
  trademarkOrBrandName String?
  contractType String?
  companyStatus String?
  preferredConsultationTime String?
  createdAt DateTime @default(now())
}

model Template {
  id String @id @default(cuid())
  name String
  sequenceName String?
  segment Segment
  messageType MessageType
  jurisdiction Jurisdiction @default(OTHER)
  subject String
  bodyMarkdown String
  lockedLegalLanguage String
  editableFields Json
  version Int @default(1)
  status ApprovalStatus @default(draft)
  approvedAt DateTime?
  approvedById String?
  approvedBy User? @relation("TemplateApprover", fields: [approvedById], references: [id])
  containsTestimonial Boolean @default(false)
  documentedNyException Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  messages OutboundMessage[]
}

model Campaign {
  id String @id @default(cuid())
  name String
  segment Segment
  messageType MessageType
  status ApprovalStatus @default(draft)
  approvedAt DateTime?
  approvedById String?
  approvedBy User? @relation("CampaignApprover", fields: [approvedById], references: [id])
  createdAt DateTime @default(now())
  messages OutboundMessage[]
}

model OutboundMessage {
  id String @id @default(cuid())
  leadId String
  lead Lead @relation(fields: [leadId], references: [id])
  templateId String
  template Template @relation(fields: [templateId], references: [id])
  campaignId String?
  campaign Campaign? @relation(fields: [campaignId], references: [id])
  subjectPreview String
  bodyPreview String
  finalSubject String?
  finalBody String?
  templateVersion Int
  complianceStatus String
  complianceReasons Json
  status QueueStatus @default(pending_review)
  approvedAt DateTime?
  approvedById String?
  approvedBy User? @relation("MessageApprover", fields: [approvedById], references: [id])
  sentAt DateTime?
  failureReason String?
  providerMessageId String?
  createdAt DateTime @default(now())
}

model ComplianceOverride {
  id String @id @default(cuid())
  targetType String
  targetId String
  reason String
  createdById String
  createdBy User @relation(fields: [createdById], references: [id])
  createdAt DateTime @default(now())
}

model ProhibitedClaim {
  id String @id @default(cuid())
  phrase String @unique
  enabled Boolean @default(true)
  createdAt DateTime @default(now())
}

model AuditLog {
  id String @id @default(cuid())
  actorId String?
  actor User? @relation(fields: [actorId], references: [id])
  action String
  entityType String
  entityId String
  metadata Json
  createdAt DateTime @default(now())
}

model Resource {
  id String @id @default(cuid())
  title String
  segment Segment
  markdownContent String
  version Int @default(1)
  status ApprovalStatus @default(draft)
  approvedAt DateTime?
  approvedById String?
  approvedBy User? @relation("ResourceApprover", fields: [approvedById], references: [id])
  disclaimer String
  versionHistory Json
  createdAt DateTime @default(now())
}

model LandingPage {
  id String @id @default(cuid())
  segment Segment @unique
  headline String
  bodyMarkdown String
  resourceId String?
  bookingCta String
  disclaimer String
  intakeTrigger String
  updatedAt DateTime @updatedAt
}

model Consultation {
  id String @id @default(cuid())
  leadId String
  lead Lead @relation(fields: [leadId], references: [id])
  preferredTime String?
  scheduledAt DateTime?
  status String @default("requested")
  attorneyOverrideReason String?
  createdAt DateTime @default(now())
}
